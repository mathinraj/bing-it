{
  "manifest_version": 3,
  "name": "Bing it",
  "version": "2.0.0",
  "description": "Automated Bing searches with human-like behavior — just Bing it!",
  "permissions": [
    "tabs",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "*://www.bing.com/*",
    "*://trends.google.com/*"
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.bing.com/*"],
      "js": ["scripts/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "options_page": "options/options.html"
}
